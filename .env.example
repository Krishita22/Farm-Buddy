# ===== FarmAgent — Configuration =====

# LLM — Llama 3 via Ollama (local, no internet needed)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3

# TTS — ElevenLabs (premium, online) + Piper (offline fallback)
# Get your key: https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=

# STT — Whisper (local, no internet)
WHISPER_MODEL_SIZE=small

# TTS Offline Fallback — Piper (local)
PIPER_VOICES_DIR=./backend/models/piper_voices
PIPER_DEFAULT_VOICE=en_US-lessac-medium

# Memory — HarperDB (Harper AI track)
HARPER_URL=http://localhost:9925
HARPER_USERNAME=HDB_ADMIN
HARPER_PASSWORD=password123
HARPER_SCHEMA=farm_agent

# Weather — Open-Meteo (free, no key needed)
WEATHER_CACHE_HOURS=6

# Email (for verification codes — optional, shows code in UI if not set)
# To enable: https://myaccount.google.com/apppasswords → generate app password
SMTP_EMAIL=
SMTP_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Database
DATABASE_URL=sqlite:///./farmagent.db
FRONTEND_URL=http://localhost:5173
OFFLINE_MODE=true
